# Copy this file to .env and fill in your own values.
# Never commit the real .env file to version control.

# Required: your Groq API key (free tier, no credit card needed)
# Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk-your-key-here

# Groq model (OpenAI-compatible chat completions, free tier)
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Local embedding model (fastembed/ONNX - downloaded once on first run, no API key/cost)
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# CORS - comma separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# NOAA CO-OPS application name (free text identifier, not a secret)
NOAA_APPLICATION_NAME=OceanGPT
